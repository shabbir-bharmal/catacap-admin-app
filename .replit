modules = ["nodejs-20", "web", "postgresql-16"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 5002
externalPort = 3002

[[ports]]
localPort = 8200
externalPort = 3001

[[ports]]
localPort = 9999
externalPort = 3003

[deployment]
deploymentTarget = "autoscale"
build = ["sh", "-c", "pnpm run build"]
run = ["node", "./dist/index.cjs"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000

[userenv]

[userenv.shared]
VITE_SUPABASE_URL = "https://rbqtdruqcmikcowrqzoj.supabase.co"
VITE_SUPABASE_STORAGE_BUCKET = "production"
